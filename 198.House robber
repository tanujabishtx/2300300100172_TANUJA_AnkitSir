class Solution {
    public int Solve(int[] nums, int i, int[] dp) {
        int n = nums.length;
        if(i >= n) return 0;
        if(dp[i] != -1) 
        {
            return dp[i];
        }
        int takefirst = nums[i] + Solve(nums, i + 2, dp);
        int skipfirst = Solve(nums, i + 1, dp);
        dp[i] = Math.max(takefirst, skipfirst);
        return dp[i];
    }
    public int rob(int[] nums) {
        int n = nums.length;
        int[] dp = new int[n];
        for(int i = 0; i < n; i++) {
            dp[i] = -1;
        }
        return Solve(nums, 0, dp);
    }
}
